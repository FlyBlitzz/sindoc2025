                    overflow-wrap: break-word;
                    }
        </style>
    </head>

    <body>

        {% set margin_top = 10 %}
        {% set canEdit = app.session.get('canEdit') is not null ? app.session.get('canEdit') : false %}

        {# Header #}
        {% include 'header.html.twig' with { canEdit: canEdit } %}
            
            <div class="mainContainer">

            {# {% endif %} #}
            {% for message in app.session.flashBag.get('info') %}
