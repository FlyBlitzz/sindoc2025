    <!-- Scripts d'initialisation CKEditor 5 -->
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    // Délai pour laisser le temps à tous les formulaires de se charger
                    setTimeout(function() {
                        // Initialise CKEditor 5 sur tous les champs avec la classe .ckeditor-field
                        const ckeditorFields = document.querySelectorAll('.ckeditor-field');
                        
                        ckeditorFields.forEach(function(field) {
                            // Vérifie si CKEditor 5 est disponible et si le champ n'est pas déjà initialisé
                            if (typeof ClassicEditor !== 'undefined' && !field.classList.contains('ck5-initialized')) {
                                field.classList.add('ck5-initialized');
                                
                                ClassicEditor
                                    .create(field, {
                                        // Configuration pour seulement gras et italique
                                        toolbar: ['bold', 'italic'],
                                        language: 'fr',
                                        height: '150px'
                                    })
                                    .then(function(editor) {
                                        console.log('CKEditor 5 initialisé pour:', field.name || field.id);
                                    })
                                    .catch(function(error) {
                                        console.log('CKEditor 5 non disponible pour ce champ, utilisation par défaut');
                                    });
                            }
                        });
                    }, 1000); // 1 seconde de délai
                });
                
                // Réinitialise CKEditor si du contenu est chargé dynamiquement (AJAX)
                document.addEventListener('ajaxComplete', function() {
                    setTimeout(function() {
                        document.querySelectorAll('.ckeditor-field:not(.ck5-initialized)').forEach(function(field) {
                            if (typeof ClassicEditor !== 'undefined') {
                                field.classList.add('ck5-initialized');
                                ClassicEditor.create(field, {
                                    toolbar: ['bold', 'italic'],
                                    language: 'fr'
                                });
                            }
                        });
                    }, 500);
                });
            </script>
    </body>
</html>