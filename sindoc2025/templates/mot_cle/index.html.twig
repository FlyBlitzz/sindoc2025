{% extends 'base.html.twig' %}

{% block title %}Liste des Mots Cles{% endblock %}

{% block body %}
<head>
    <link rel="stylesheet" href="{{ asset('css/ajoutFiche.css') }}">
     <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
</head>

<div class="classs" style="width: 84%; margin: 150px auto; margin-top: 0px;">
    <div class="row">
        {% include "_partials/_adminnav.html.twig" %}
        <main class="col-9 container border border-light bg-white">
            <h1>Liste des Mots Clés</h1>
             <form method="GET" action="{{ path('fiche_list') }}" class="row g-2 align-items-center">
                <div class="col-12 col-md-auto">
                    <select id="index" name="index" class="form-select">
                        <option value="0">Tous les indexs</option>
                        {% for index in indexes %}
                            <option value="{{ index.idindex }}" {% if index.idIndex == selectedIndex %}selected{% endif %}>
                                {{ index.nom }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-12 col-md-auto">
                    <button type="submit" class="btn btn-primary w-100">Filtrer</button>
                </div>
            </form>
            <a href="{{ path('mot_cle_app_mot_cle_new') }}" class="btn btn-primary m-4"> + Créer un nouveau</a>
            <div class="table-responsive">
                <table class="table" id="userTable">
                    <thead>
                        <tr>
                            <th>Réfèrence</th>
                            <th>Dénomination</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for mot_cle in mot_cles %}
                            <tr>
                                <td>{{ mot_cle.reference }}</td>
                                <td>{{ mot_cle.denomination }}</td>
                                <td>
                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="{{ path('mot_cle_app_mot_cle_show', {'id': mot_cle.idMotCle}) }}" class="btn btn-outline-primary rounded tooltip-link" data-tooltip="Afficher le mot clé">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="{{ path('mot_cle_app_mot_cle_edit', {'id': mot_cle.idMotCle}) }}" class="btn btn-outline-primary rounded tooltip-link" data-tooltip="Modifier le mot clé">
                                            <i class="fas fa-pencil"></i>
                                        </a>
                                        <form method="post" action="{{ path('mot_cle_app_mot_cle_delete', {'id': mot_cle.idMotCle}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer ce mot clé ?');" class="d-inline">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ mot_cle.idMotCle) }}">
                                            <button type="submit" class="btn btn-outline-danger rounded tooltip-link" data-tooltip="Supprimer le mot clé">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4">Aucun mot clé trouvé!</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</div>
<script>
$(document).ready(function() {
    $('#userTable').DataTable({
        language: {
            url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/French.json'
        },
        responsive: true,
    });
});
</script>
    <style>

        .tooltip-link {
            position: relative;
            display: inline-block;
            text-decoration: none;
            cursor: pointer;
        }


        .tooltip-link::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: 120%;
            left: 50%;
            transform: translateX(-50%);
            background-color: rgba(0, 0, 0, 0.8);
            color: white;
            padding: 5px 10px;
            font-size: 12px;
            white-space: nowrap;
            border-radius: 5px;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s, visibility 0.3s;
        }

        /* Show tooltip on hover */
        .tooltip-link:hover::after {
            opacity: 1;
            visibility: visible;
        }
    </style>
{% endblock %}