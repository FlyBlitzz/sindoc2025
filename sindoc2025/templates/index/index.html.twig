{% extends 'base.html.twig' %}

{% block title %}Liste des index{% endblock %}

{% block body %}
<head>
       <link rel="stylesheet" href="{{ asset('css/ajoutFiche.css') }}">
        <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
</head>
   <div class="classs" style="width: 84%;     margin: 150px auto; margin-top: 0px;">

        <div class="row">
          {% include "_partials/_adminnav.html.twig"%}
          <main class="col-9 container border border-light bg-white ">
            <h1> Liste des index</h1>
              <a href="{{ path('index_app_index_new') }}" class="btn btn-primary my-4">+ Créer un nouveau</a>
        <div class="table-responsive">
            <table class="table" id="userTable">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Actions</th>
                <th>Visibilité</th>
            </tr>
        </thead>
        <tbody>
        {% for index in indices %}
            <tr>
                <td>{{ index.idindex }}</td>
                <td>{{ index.nom }}</td>
                <td>
    <div class="d-flex flex-wrap gap-2">
        <a href="{{ path('index_app_index_show', {'id': index.idindex}) }}" class="btn btn-outline-primary rounded mx-2 tooltip-link" data-tooltip="Afficher l'index">
            <i class="fas fa-eye"></i>
        </a>
        <a href="{{ path('index_app_index_edit', {'id': index.idindex}) }}" class="btn btn-outline-primary rounded mx-2 tooltip-link" data-tooltip="Modifier l'index">
            <i class="fas fa-pencil"></i>
        </a>
        <form method="post" action="{{ path('index_app_index_delete', {'id': index.idindex}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet index?');" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ index.idindex) }}">
            <button type="submit" class="btn btn-outline-danger rounded mx-2 tooltip-link" data-tooltip="Supprimer l'index">
                <i class="fas fa-trash"></i>
            </button>
        </form>
        <a href="#"  onclick="afficherMotsCles('{{ index.idindex }}'); return false;" class="btn btn-outline-primary rounded mx-2 tooltip-link" data-tooltip="Voir les mots clés">
            <i class="fas fa-key"></i>
        </a>
        <a href="{{ path('app_index_auth', { id: index.idindex }) }}" class="btn btn-outline-secondary rounded mx-2 tooltip-link" data-tooltip="Donner des autorisations">
            <i class="fas fa-user-shield"></i>
        </a>
    </div>
    </td>
                 <td>
                 <form method="post" action="{{ path('app_index_toggle_visibility', {'id': index.idindex}) }}" >
                        <input type="hidden" name="_token" value="{{ csrf_token('toggle_visibility' ~ index.idindex) }}">
                        <label class="switch">
                            <input type="checkbox" {{ index.visible ? 'checked' : '' }} onchange="this.form.submit()">
                            <span class="slider round"></span>
                        </label>
                     </form>
                     </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucun index trouvé ! </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
    </div>
    </div>


<script>

    function fetchBaseHTML(callback) {
        fetch('get_base_html')
            .then(response => response.text())
            .then(html => callback(html))
            .catch(error => console.error('Erreur lors de la récupération du fichier base.html.twig : ', error));
    }

    function afficherMotsCles(indexId) {

        window.location.href = "{{ path('app_mots_cles', {'indexId': 'INDEX_ID'}) }}".replace('INDEX_ID', indexId);
    }

    $(document).ready(function() {
        $('#userTable').DataTable({
            language: {
                url: '//cdn.datatables.net/plug-ins/1.13.6/i18n/French.json'
            },
            responsive: true,
        });
    });
</script>

<style>
.switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 25px;
}
/* Tooltip container */
.tooltip-link {
    position: relative;
    display: inline-block;
    text-decoration: none;
    cursor: pointer;
}

/* Tooltip text */
.tooltip-link::after {
    content: attr(data-tooltip); /* Use the attribute value */
    position: absolute;
    bottom: 120%; /* Position above the link */
    left: 50%;
    transform: translateX(-50%);
    background-color: rgba(0, 0, 0, 0.8);
    color: white;
    padding: 5px 10px;
    font-size: 12px;
    white-space: nowrap;
    border-radius: 5px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s, visibility 0.3s;
}

/* Show tooltip on hover */
.tooltip-link:hover::after {
    opacity: 1;
    visibility: visible;
}
/* Make switch size adaptive for different screen sizes */
@media (max-width: 768px) {
    .switch {
        width: 40px;
        height: 20px;
    }
}

.switch input {
    opacity: 0;
    width: 0;
    height: 0;
}

.slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: .4s;
    border-radius: 25px;
}

.slider:before {
    position: absolute;
    content: "";
    height: 18px;
    width: 18px;
    left: 4px;
    bottom: 3px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
}

/* Checked state */
input:checked + .slider {
    background-color: #0d6efd; /* Bootstrap primary color */
}

input:checked + .slider:before {
    transform: translateX(24px);
}

/* Smaller screens */
@media (max-width: 768px) {
    .slider:before {
        height: 14px;
        width: 14px;
        left: 3px;
        bottom: 3px;
    }
    
    input:checked + .slider:before {
        transform: translateX(18px);
    }
}
</style>

{% endblock %}
